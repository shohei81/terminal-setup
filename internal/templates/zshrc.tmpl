# BEGIN terminal-setup
# This block is auto-generated by terminal-setup. Do not edit manually.

# --- completions & plugins ---
fpath=(/opt/homebrew/share/zsh-completions $fpath)
autoload -Uz compinit && compinit
source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh 2>/dev/null
ZSH_AUTOSUGGEST_STRATEGY=(history)

# --- history ---
HISTSIZE=10000
SAVEHIST=10000
HISTFILE="$HOME/.zsh_history"
setopt SHARE_HISTORY HIST_IGNORE_ALL_DUPS

# --- prompt ---
eval "$(starship init zsh)"

# --- aliases ---
alias ls='lsd'
alias ll='lsd -la'
alias ..='cd ..'
alias ...='cd ../..'
alias g='git'

# --- functions ---
mkcd() { mkdir -p "$1" && cd "$1"; }

# --- greeting ---
{{if .FastfetchModules -}}
command -v fastfetch >/dev/null && fastfetch --logo none --structure "{{.FastfetchStructure}}"
{{- end}}
{{if .HasFzf}}
# fzf
source <(fzf --zsh) 2>/dev/null
{{end -}}
{{if .HasZoxide}}
# zoxide
eval "$(zoxide init zsh)"
{{end -}}
{{if .HasYazi}}
# yazi (exits to current directory)
y() {
  local tmp cwd
  tmp="$(mktemp -t yazi-cwd.XXXXXX)"
  command yazi "$@" --cwd-file="$tmp"
  IFS= read -r -d "" cwd < "$tmp"
  [ -n "$cwd" ] && [ "$cwd" != "$PWD" ] && builtin cd -- "$cwd"
  rm -f -- "$tmp"
}
{{end -}}
# END terminal-setup
